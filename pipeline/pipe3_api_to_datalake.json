{
	"name": "pipe3_api_to_datalake",
	"properties": {
		"activities": [
			{
				"name": "Copy data from Rest API-GitHub to datalake",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "JsonSource",
						"storeSettings": {
							"type": "HttpReadSettings",
							"requestMethod": "GET"
						},
						"formatSettings": {
							"type": "JsonReadSettings"
						}
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "githun_api_to_datalake_ds",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "adls_ds1",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": []
	}
}